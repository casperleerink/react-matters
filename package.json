{
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --continue",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "publish": "cd packages/react-matters && pnpm publish --access public",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=react-matters && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.22.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "turbo": "latest"
  },
  "packageManager": "pnpm@10.7.1"
}
